# ============================================================
# VARIABLES DE ENTORNO - SISTEMA TRANSPORTE INTIWATANA
# Copiar como .env y ajustar valores reales
# ⚠ NUNCA subir el .env real a git (está en .gitignore)
# ============================================================

# ── Servidor ────────────────────────────────────────────────
SERVER_PORT=8080

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/transporte_db
DB_USERNAME=postgres
DB_PASSWORD=TU_PASSWORD_AQUI
DB_POOL_MAX=10
DB_POOL_MIN=3

# ── JPA ──────────────────────────────────────────────────────
# Opciones: update | validate | none
# En producción usar 'validate' (nunca 'update')
JPA_DDL_AUTO=update

# ── JWT ───────────────────────────────────────────────────────
# Generar secret: python3 -c "import base64,secrets;print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET=GENERA_UN_SECRET_SEGURO_AQUI
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_MS=604800000

# ── CORS ─────────────────────────────────────────────────────
# Desarrollo:
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Producción (ejemplo):
# CORS_ALLOWED_ORIGINS=https://tu-frontend.com

# ── Logging ──────────────────────────────────────────────────
# Opciones: DEBUG | INFO | WARN | ERROR
LOG_LEVEL_APP=INFO
LOG_FILE=logs/sistema-transporte.log
